generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  email        String    @unique
  password     String
  displayName  String?
  bio          String?
  emailVerified Boolean  @default(false)
  otp          String?
  otpExpiresAt DateTime?
  phone        String?
  kycTier      Int       @default(0) // 0: basic, 1: BVN/NIN verified
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  wallet            Wallet?
  wagersCreated     Wager[]            @relation("WagerCreator")
  wagerParticipants WagerParticipant[]
  disputes          Evidence[]
  notifications     Notification[]
  bankAccount       BankAccount?
}

model Wallet {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @unique @db.ObjectId
  user             User     @relation(fields: [userId], references: [id])
  availableBalance Float    @default(0.00)
  escrowBalance    Float    @default(0.00)
  lockedBalance    Float    @default(0.00)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ledgerEntries LedgerEntry[]
}

model LedgerEntry {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  walletId      String       @db.ObjectId
  wallet        Wallet       @relation(fields: [walletId], references: [id])
  transactionId String?      @db.ObjectId
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  amount        Float        // Positive for credit, negative for debit
  type          String       // 'DEPOSIT', 'WITHDRAWAL', 'ESCROW_LOCK', 'ESCROW_RELEASE', 'WIN', 'FEE'
  description   String?
  createdAt     DateTime     @default(now())

  @@index([walletId])
}

model Transaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  reference   String   @unique
  status      String   // 'PENDING', 'SUCCESS', 'FAILED'
  type        String   // 'DEPOSIT', 'WITHDRAWAL'
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ledgerEntries LedgerEntry[]
}

model Wager {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  creatorId   String   @db.ObjectId
  creator     User     @relation("WagerCreator", fields: [creatorId], references: [id])
  description String
  totalPot    Float    @default(0.00)
  status      String   // 'PENDING_FUNDING', 'ACTIVE', 'SETTLED', 'DISPUTED', 'CANCELLED', 'EXPIRED'
  winnerId    String?  @db.ObjectId // Set when settled
  isSymmetric Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants WagerParticipant[]
  dispute      Dispute?

  @@index([status, expiresAt])
  @@index([creatorId])
}

model WagerParticipant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  wagerId     String   @db.ObjectId
  wager       Wager    @relation(fields: [wagerId], references: [id])
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  side        String   // 'CREATOR', 'CHALLENGER'
  amount      Float
  status      String   // 'PENDING', 'FUNDED', 'REFUNDED'
  settleVote  String?  @db.ObjectId // userId they voted as winner
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([wagerId, userId])
  @@index([userId])
}

model Dispute {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  wagerId    String   @unique @db.ObjectId
  wager      Wager    @relation(fields: [wagerId], references: [id])
  status     String   // 'OPEN', 'RESOLVED'
  resolution String?  // 'WINNER_A', 'WINNER_B', 'REFUND'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  evidence   Evidence[]
}

model Evidence {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  disputeId  String   @db.ObjectId
  dispute    Dispute  @relation(fields: [disputeId], references: [id])
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  mediaUrl   String?
  textClaim  String?
  proofType  String?  // 'screenshot', 'document', 'link'
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  type      String   // 'WAGER_CREATED', 'WAGER_JOINED', 'SETTLEMENT', 'DISPUTE_OPENED', 'DISPUTE_RESOLVED'
  message   String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model BankAccount {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  accountNumber String
  accountName   String
  bankName      String
  bankCode      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
